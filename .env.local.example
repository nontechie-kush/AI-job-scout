# ============================================================
# CareerPilot AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Server-side only, never expose to client

# ── Anthropic (Claude API) ───────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth (Gmail + Calendar) ─────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Scopes needed: gmail.readonly, calendar.readonly
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback   # Change to production URL on Vercel

# ── Web Push (VAPID Keys) ────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:pilot@careerpilot.ai

# ── Scraping Services ────────────────────────────────────────
# ScraperAPI: https://www.scraperapi.com (for Glassdoor, AmbitionBox, Naukri)
SCRAPERAPI_KEY=your-scraperapi-key
# ScrapingBee (backup): https://www.scrapingbee.com
SCRAPINGBEE_KEY=your-scrapingbee-key

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Change to https://careerpilot.ai on Vercel
CRON_SECRET=generate-a-long-random-string-here   # Protects /api/cron/* endpoints
